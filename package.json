{
  "name": "@institute-alterna/www-studio",
  "private": true,
  "version": "0.0.1-beta",
  "main": "package.json",
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "deploy": "sanity deploy",
    "deploy-graphql": "sanity graphql deploy"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/institute-alterna/www-studio.git"
  },
  "keywords": [
    "sanity"
  ],
  "author": "Institute Alterna",
  "license": "MIT",
  "dependencies": {
    "@sanity/vision": "^5.26.0",
    "react": "^19.1",
    "react-dom": "^19.1",
    "sanity": "^5.26.0",
    "styled-components": "^6.1.18"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "vitest": "^4",
    "@types/node": "^22.19.19",
    "@types/react": "^19.1",
    "eslint": "^9.28",
    "prettier": "^3.5",
    "typescript": "^5.8"
  },
  "overrides": {
    "minimatch": ">=10.2.3",
    "js-yaml": ">=4.1.1",
    "uuid": ">=11.1.1"
  },
  "prettier": {
    "semi": false,
    "printWidth": 100,
    "bracketSpacing": false,
    "singleQuote": true
